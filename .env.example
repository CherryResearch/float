### secrets go here :)

SECRET_KEY=your_secret_key
DATABASE_URL=postgresql://user:password@localhost/db
VITE_API_BASE_URL=http://localhost:8000

# OpenAI API key used for external requests
OPENAI_API_KEY=
# Fallback API key if OPENAI_API_KEY is not set
API_KEY=
# OpenAI Chat Completion API endpoint
EXTERNAL_API_URL=https://api.openai.com/v1/chat/completions
# Local language model endpoint
LOCAL_LLM_URL=http://localhost:11433
# Default model used when calling the OpenAI API
OPENAI_MODEL=gpt-3.5-turbo
# Name of the dynamic model to serve via Ollama
DYNAMIC_MODEL=mistral
# Port for the dynamic model server
DYNAMIC_PORT=11434
# MCP server URL (auto-starts on a free port if left blank)
MCP_SERVER_URL=
# Authentication token for MCP server
MCP_API_TOKEN=
# Vector store backend: chroma, weaviate, or auto
FLOAT_RAG_BACKEND=chroma
# Optional Weaviate endpoint settings
FLOAT_WEAVIATE_URL=http://localhost:8080
FLOAT_WEAVIATE_GRPC_PORT=50051
FLOAT_AUTO_START_WEAVIATE=false
# Directory for storing conversation history
FLOAT_CONV_DIR=./data/conversations
